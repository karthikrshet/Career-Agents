l\": \"Mid\",\n      \"career_stage\": \"Transition\",\n      \"industry\": \"All\",\n      \"skills\": [\n        \"Career Strategy\",\n        \"Professional Development\",\n        \"Career Growth\",\n        \"Career Milestones\",\n        \"No-nonsense\",\n        \"Career\"\n      ],\n      \"companies\": [],\n      \"related_agents\": [\n        \"freelance-career-advisor\",\n        \"graduate-career-advisor\",\n        \"hr-interview-coach\"\n      ],\n      \"related_workflows\": [\n        \"fresher-placement\",\n        \"internship-hunt\"\n      ],\n      \"popularity_score\": 66\n    }\n  ],\n  \"recommended_workflows\": [\n    {\n      \"id\": \"ats-optimization\",\n      \"name\": \"ATS Optimization\",\n      \"category\": \"resume workflows\",\n      \"filename\": \"workflows/ats-optimization.md\",\n      \"description\": \"A repeatable resume operating system for candidates who apply through portals, campus systems, and enterprise hiring platforms. Optimizes resume structures, headings, and keyword mapping to survive ATS parsing.\",\n      \"recommended_agents\": [\n        \"ats-resume-reviewer\",\n        \"resume-strategist\",\n        \"job-search-strategist\",\n        \"linkedin-growth-advisor\",\n        \"placement-coach\"\n      ],\n      \"prerequisites\": [\n        \"Current resume in editable format\",\n        \"Target role family (e.g. backend developer, data analyst)\",\n        \"At least three representative job descriptions\"\n      ]\n    },\n    {\n      \"id\": \"fresher-placement\",\n      \"name\": \"Fresher Placement\",\n      \"category\": \"career workflows\",\n      \"filename\": \"workflows/fresher-placement.md\",\n      \"description\": \"Step-by-step guidance for college students and recent grads navigating their first job hunt and campus placement cycles.\",\n      \"recommended_agents\": [\n        \"placement-coach\",\n        \"graduate-career-advisor\",\n        \"ats-resume-reviewer\",\n        \"mock-interviewer\",\n        \"networking-coach\"\n      ],\n      \"prerequisites\": [\n        \"Target college graduation timeline\",\n        \"List of eligible companies visiting campus\",\n        \"Current draft resume\"\n      ]\n    }\n  ],\n  \"recommended_bundles\": [\n    {\n      \"id\": \"ai-engineer-bundle\",\n      \"name\": \"AI Engineer & Scientist Bundle\",\n      \"description\": \"System frameworks, fine-tuning scripts, MLOps orchestration, prompt formatting matrices, and RAG architectures for AI engineers.\",\n      \"agents\": [\n        \"ai-agent-architect\",\n        \"llm-engineer\",\n        \"rag-architect\",\n        \"prompt-engineer\",\n        \"ai-engineer-career-coach\",\n        \"mlops-engineer\"\n      ],\n      \"workflows\": [\n        \"technical-interview-week\",\n        \"faang-preparation\"\n      ],\n      \"career_paths\": [\n        \"ai-engineer\",\n        \"software-engineer\"\n      ],\n      \"skills\": [\n        \"Prompt Optimization\",\n        \"Vector Embeddings\",\n        \"Fine-Tuning\",\n        \"Agentic Loops\",\n        \"PyTorch Scale Training\"\n      ],\n      \"companies\": [\n        \"OpenAI\",\n        \"Google\",\n        \"Meta\",\n        \"Microsoft\",\n        \"Databricks\"\n      ]\n    },\n    {\n      \"id\": \"faang-bundle\",\n      \"name\": \"FAANG & Top Tech Prep Bundle\",\n      \"description\": \"Pre-packaged prep assets and workflows optimized for passing high-bar coding, system design, and behavioral loops at FAANG and tier-1 companies.\",\n      \"agents\": [\n        \"google-interview-coach\",\n        \"amazon-interview-coach\",\n        \"meta-interview-coach\",\n        \"microsoft-interview-coach\",\n        \"system-design-coach\",\n        \"technical-interview-coach\",\n        \"behavioral-interview-specialist\",\n        \"mock-interviewer\"\n      ],\n      \"workflows\": [\n        \"faang-preparation\",\n        \"technical-interview-week\",\n        \"hr-interview-week\"\n     